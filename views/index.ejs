<!DOCTYPE html>

<html lang="fr">

  <%- include("./partials/head") -%>

  <body>

    <%- include("./partials/header-index") -%>

    <%- include("./partials/sideNav") -%>

    <div id="starterRecipes" class="allRecipes">
    <% for (const recipe of starterRecipes) { %>
      <div class=recipeThumbnail>
        <a href="/recipe/<%- recipe.id -%>">
        <img class="recipeThumbnailPhoto" src="<%- recipe.thumbnailPictureUrl -%>"/>
        <div class="recipeThumbnailLegend">
          <div class="recipeThumbnailCategory"><%- recipe.category -%></div>
          <div class="recipeThumbnailName"><%- recipe.name -%></div>
        </div>
        </a>
      </div>
    <% } %>
    </div>

    <div id="dishRecipes" class="allRecipes">
    <% for (const recipe of dishRecipes) { %>
      <div class=recipeThumbnail>
        <a href="/recipe/<%- recipe.id -%>">
        <img class="recipeThumbnailPhoto" src="<%- recipe.thumbnailPictureUrl -%>"/>
        <div class="recipeThumbnailLegend">
          <div class="recipeThumbnailCategory"><%- recipe.category -%></div>
          <div class="recipeThumbnailName"><%- recipe.name -%></div>
        </div>
      </div>
    <% } %>
    </div>

    <div id="dessertRecipes" class="allRecipes">
    <% for (const recipe of dessertRecipes) { %>
      <div class=recipeThumbnail>
        <a href="/recipe/<%- recipe.id -%>">
        <img class="recipeThumbnailPhoto" src="<%- recipe.thumbnailPictureUrl -%>"/>
        <div class="recipeThumbnailLegend">
          <div class="recipeThumbnailCategory"><%- recipe.category -%></div>
          <div class="recipeThumbnailName"><%- recipe.name -%></div>
        </div>
      </div>
    <% } %>
    </div>

    <script>
      const starterRecipes = <%- starterRecipesJSON %>;    
      const dishRecipes = <%- dishRecipesJSON %>;
      const dessertRecipes = <%- dessertRecipesJSON %>;         
    </script>

    <script src="/js/index.js"></script>

  </body>

</html>
